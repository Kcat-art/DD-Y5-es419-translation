msgctxt " 	　	　	93	2975	2882"
msgid "They asked me to keep an eye on you."
msgstr ""

msgctxt " 	　	分	91	3091	3000"
msgid "That's why I put myself behind bars."
msgstr ""

msgctxt " 	　	　	125	3246	3121"
msgid "Meanin' that whole spiel about\\r\n"
"ya gettin' a decade for murder..."
msgstr ""

msgctxt " 	　	　	66	3331	3265"
msgid "A fabrication, of course."
msgstr ""

msgctxt " 	　	　	161	3507	3346"
msgid "I knew a sob story like that\\r\n"
"would catch your attention, Saejima-san."
msgstr ""

msgctxt " 	　	　	111	3637	3526"
msgid "Why do all that just to spy on me?"
