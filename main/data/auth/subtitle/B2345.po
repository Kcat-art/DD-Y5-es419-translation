msgctxt " 	　	　	104	7351	7247"
msgid "What're ya gettin' at?\\r\n"
"Explain!"
msgstr ""

msgctxt " 	　	　	60	7606	7546"
msgid "The death of Goro Majima."
msgstr ""

msgctxt " 	　	分	60	7691	7631"
msgid "That was our sign."
msgstr ""

msgctxt " 	　	　	126	7836	7710"
msgid "It was time for us to\\r\n"
