msgstr ""

msgctxt " 	　	　	60	9206	9146"
msgid "But why?"
msgstr ""

msgctxt " 	　	分	122	9355	9233"
msgid "What was so important about gettin'\\r\n"
"me back on the outside?"
msgstr ""

msgctxt " 	　	　	60	9489	9429"
msgid "Well..."
