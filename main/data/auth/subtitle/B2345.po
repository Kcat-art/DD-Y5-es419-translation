msgctxt " 	　	分	80	3921	3841"
msgid "The opposite, in fact."
msgstr ""

msgctxt " 	　	　	60	4004	3944"
msgid "What?"
msgstr ""

msgctxt " 	　	　	138	4234	4096"
msgid "I had one job: to control\\r\n"
"the length of your sentence."
msgstr ""

msgctxt " 	　	分	129	4365	4236"
msgid "Figure out the right timing,\\r\n"
"help you find your way to freedom..."
msgstr ""

msgctxt " 	　	　	100	4467	4367"
msgid "And finally, bring you here to Tsukimino."
msgstr ""

msgctxt " 	　	　	152	4653	4501"
msgid "Quit takin' me for a ride.\\r\n"
"No chance ya coulda done that."
msgstr ""

msgctxt " 	　	　	60	4818	4758"
msgid "Think back for a second."
msgstr ""

msgctxt " 	　	分	136	4977	4841"
msgid "You would have been out on parole\\r\n"
"no problem if someone hadn't interfered."
msgstr ""

msgctxt " 	　	　	60	5079	5019"
msgid "But who woulda done that?"
