msgctxt " 	　	分	71	8270	8199"
msgid "Every bit of it a part of our plan."
msgstr ""

msgctxt " 	　	　	129	8445	8316"
msgid "My bro died... 'cause of me?"
msgstr ""

msgctxt " 	　	分	60	8534	8474"
msgid "The hell's it all mean?"
msgstr ""

msgctxt " 	　	OK	184	8752	8568"
msgid "It wasn't just that. The warden's death, getting\\r\n"
