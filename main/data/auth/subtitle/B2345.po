msgctxt " 	　	　	60	5230	5170"
msgid "Ya can't mean..."
msgstr ""

msgctxt " 	　	　	60	5308	5248"
msgid "Kugihara."
msgstr ""

msgctxt " 	　	分	151	5462	5311"
msgid "He was a tool meant to extend your\\r\n"
"prison stay until the proper time."
