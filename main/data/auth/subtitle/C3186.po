msgctxt " 	　	　	60	3218	3158"
msgid "I really mean it!"
msgstr ""

msgctxt " 	　	　	164	3495	3331"
msgid "He promised he'd come to your concert in Tokyo."
msgstr ""

msgctxt " 	　	　	107	3625	3518"
msgid "I'll ask you again as it gets closer."
