msgctxt " 	　	　	60	7085	7025"
msgid "Why's that?"
msgstr ""

msgctxt " 	　	　	77	7204	7127"
msgid "She's clearly fallen for you."
msgstr ""

msgctxt " 	　	　	62	7350	7288"
msgid "I'm her father."
msgstr ""

msgctxt " 	　	分	161	7530	7369"
msgid "I can't bear to see her struggle with\\r\n"
"feelings that'll never be reciprocated."
msgstr ""

msgctxt " 	　	　	89	8020	7931"
msgid "Kiryu-san. Here."
msgstr ""

msgctxt " 	　	　	60	8588	8528"
msgid "What's this?"
msgstr ""

msgctxt " 	　	　	89	8691	8602"
msgid "A declaration dissolving\\r\n"
"the Yamagasa Family."
msgstr ""

msgctxt " 	　	分	156	8873	8717"
msgid "Can I entrust this to you,\\r\n"
"to take to the police?"
msgstr ""

msgctxt " 	　	　	60	8964	8904"
msgid "Why?"
msgstr ""

msgctxt " 	　	分	60	9039	8979"
msgid "Why dissolve the family?"
msgstr ""

msgctxt " 	　	　	177	9233	9056"
msgid "My men have grown too big\\r\n"
"to live in my little castle anymore."
msgstr ""

msgctxt " 	　	　	89	9323	9234"
msgid "The Yamagasa Family's always been small."
msgstr ""

msgctxt " 	　	分	159	9507	9348"
msgid "But it seems I took in too many children."
msgstr ""

msgctxt " 	　	　	170	9696	9526"
msgid "And now it's even put a strain on our\\r\n"
"relationship with the Tojo Clan."
msgstr ""

msgctxt " 	　	OK	197	9926	9729"
msgid "The best I can do for my boys is to\\r\n"
"make sure they get a chance at life."
msgstr ""

msgctxt " 	　	　	60	10048	9988"
msgid "Madarame-san."
msgstr ""

msgctxt " 	　	　	94	10152	10058"
msgid "We'd cease to be yakuza anymore."
msgstr ""

msgctxt " 	　	分	182	10335	10153"
msgid "And by ceding our turf, the Tojo Clan and the\\r\n"
"Omi Alliance would no longer be gunning for us."
