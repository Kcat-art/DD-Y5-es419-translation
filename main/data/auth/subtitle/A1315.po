msgctxt " 	　	　	116	10504	10388"
msgid "That's simply the safest option now."
msgstr ""

msgctxt " 	　	　	60	10595	10535"
msgid "If you're really going through with this..."
msgstr ""

msgctxt " 	　	分	144	10752	10608"
msgid "It would only be fair if your men heard\\r\n"
"it directly from you. Right?"
msgstr ""

msgctxt " 	　	　	114	10918	10804"
msgid "There's no stopping a Kyushu man\\r\n"
"once his blood gets pumping."
msgstr ""

msgctxt " 	　	OK	186	11105	10919"
msgid "I could tell them not to poke at the Tojo Clan,\\r\n"
"and they'd still go pick up a stick."
