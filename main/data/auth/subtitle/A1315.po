msgctxt " 	　	　	124	2155	2031"
msgid "Aoyama's not the real traitor."
msgstr ""

msgctxt " 	　	　	60	2373	2313"
msgid "Are you okay?"
msgstr ""

msgctxt " 	　	　	60	2623	2563"
msgid "Kiryu-san."
msgstr ""

msgctxt " 	　	分	128	2764	2636"
msgid "It seems I owe you an apology."
msgstr ""

msgctxt " 	　	　	172	2961	2789"
msgid "The one who sent this young lady\\r\n"
"to spy on your activities in Fukuoka..."
msgstr ""

msgctxt " 	　	　	71	3048	2977"
msgid "To leak your whereabouts to the Tojo Clan..."
msgstr ""

msgctxt " 	　	分	84	3152	3068"
msgid "I'm afraid it was me."
