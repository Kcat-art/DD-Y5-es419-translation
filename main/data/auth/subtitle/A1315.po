msgctxt " 	　	　	60	3266	3206"
msgid "You?"
msgstr ""

msgctxt " 	　	　	72	3375	3303"
msgid "At Chairman Dojima's request, yes."
msgstr ""

msgctxt " 	　	分	191	3580	3389"
msgid "He wanted me to look out for you.\\r\n"
"To keep your cover in Fukuoka safe."
msgstr ""

msgctxt " 	　	　	60	3729	3669"
msgid "Daigo did that?"
msgstr ""

msgctxt " 	　	OK	193	3957	3764"
msgid "It seems Chairman Dojima knew all along\\r\n"
"that you were in hiding here."
msgstr ""

msgctxt " 	　	　	118	4076	3958"
msgid "He also knew that you had taken an alias."
msgstr ""

msgctxt " 	　	OK	259	4379	4120"
msgid "All he wanted was for you to live in peace.\\r\n"
"To not get dragged back into the fray."
msgstr ""

msgctxt " 	　	　	174	4565	4391"
msgid "That's why he came all the way down here.\\r\n"
"To ask me to help you."
msgstr ""

msgctxt " 	　	　	60	4687	4627"
msgid "He went that far?"
msgstr ""

msgctxt " 	　	　	103	4867	4764"
msgid "The head of the entire Kanto region..."
msgstr ""

msgctxt " 	　	分	133	5001	4868"
msgid "Humbled himself to ask this of some\\r\n"
"tiny outfit like the Yamagasa Family."
msgstr ""

msgctxt " 	　	　	150	5184	5034"
msgid "Not exactly a common occurrence,\\r\n"
"as I'm sure you're well aware."
msgstr ""

msgctxt " 	　	OK	204	5415	5211"
msgid "Ever since, I've been sharing the information\\r\n"
"relayed to me by Mayumi with Chairman Dojima."
