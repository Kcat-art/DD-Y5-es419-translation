msgctxt " 	　	　	61	5631	5570"
msgid "And your connection to Mayumi?"
msgstr ""

msgctxt " 	　	　	60	5716	5656"
msgid "We're family."
msgstr ""

msgctxt " 	　		82	5802	5720"
msgid "Mayumi is my daughter."
msgstr ""

msgctxt " 	　	　	101	5943	5842"
msgid "You'd send your daughter? Really?"
msgstr ""

msgctxt " 	　	　	143	6133	5990"
msgid "The fact that you were in Fukuoka\\r\n"
