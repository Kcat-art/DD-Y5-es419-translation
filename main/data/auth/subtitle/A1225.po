msgctxt " 	　	　	60	9035	8975"
msgid "Ya know it?"
msgstr ""

msgctxt " 	　	分	60	9134	9074"
msgid "Well ain't that a nice coincidence."
msgstr ""

msgctxt " 	　	OK	202	9394	9192"
msgid "I promise, no matter how rough ya get,\\r\n"
"we won't go bulldozin' the life you built here."
msgstr ""

msgctxt " 	　	　	80	9525	9445"
msgid "We'll hope for the best. See ya."
msgstr ""

