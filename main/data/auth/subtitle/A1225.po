msgctxt " 	　	分	102	2246	2144"
msgid "They could crush the Yamagasa Family\\r\n"
"without battin' an eye."
msgstr ""

msgctxt " 	　	　	138	2422	2284"
msgid "So in a flash, Nagasugai's the hottest spot\\r\n"
"in the country for yakuza types."
msgstr ""

msgctxt " 	　	　	110	2533	2423"
msgid "Nowhere else as dangerous, or crucial."
msgstr ""

msgctxt " 	　	分	88	2625	2537"
msgid "All eyes are on this town\\r\n"
"like it's ground zero."
msgstr ""

msgctxt " 	　	　	172	2840	2668"
msgid "'Course, the Tojo Clan's well aware\\r\n"
"that Watase came down to Fukuoka."
