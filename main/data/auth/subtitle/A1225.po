msgctxt " 	　	分	72	5209	5137"
msgid "Bringin' the inferno of war."
msgstr ""

msgctxt " 	　	　	83	5332	5249"
msgid "That would be catastrophic."
msgstr ""

msgctxt " 	　	OK	199	5555	5356"
msgid "Ya get it now? I need you to go talk\\r\n"
"Watase off the ledge before it comes to that."
