msgctxt " 	　	OK	185	8281	8096"
msgid "Right. Sounds like going after\\r\n"
"Watase would help us both, then."
msgstr ""

msgctxt " 	　	　	139	8450	8311"
msgid "So, what do you say?\\r\n"
"Are you in?"
msgstr ""

msgctxt " 	　	　	64	8557	8493"
msgid "Where's Watase now?"
msgstr ""

msgctxt " 	　	　	95	8680	8585"
msgid "At some club knockin' a few\\r\n"
