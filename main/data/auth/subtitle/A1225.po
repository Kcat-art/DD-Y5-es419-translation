msgctxt " 	 		157	185	28"
msgid "Aren't you a little far from home?\\r\n"
"Osaka and Fukuoka aren't exactly neighbors."
msgstr ""

msgctxt " 	　	　	94	298	204"
msgid "I got shipped down to Nagasugai."
msgstr ""

msgctxt " 	　	分	74	385	311"
msgid "'Cause of the Omi Alliance captain, Watase."
msgstr ""

msgctxt " 	　	　	163	563	400"
msgid "What? What's someone like that doing in Fukuoka?"
msgstr ""

msgctxt " 	　	　	128	714	586"
msgid "The seventh Omi chairman is\\r\n"
