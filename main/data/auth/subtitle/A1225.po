msgctxt " 	　	　	102	3515	3413"
msgid "Even if the Tojo appointed\\r\n"
"an acting chairman..."
msgstr ""

msgctxt " 	　	　	167	3695	3528"
msgid "With Dojima as a bargaining chip,\\r\n"
"the Omi could swing things in their favor."
