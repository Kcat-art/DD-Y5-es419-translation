msgctxt " 	　	　	60	3160	3100"
msgid "Yeah. The Omi."
msgstr ""

msgctxt " 	　	分	61	3222	3161"
msgid "That's most likely, anyway."
msgstr ""

msgctxt " 	　	　	132	3398	3266"
msgid "With Daigo Dojima off the board,\\r\n"
"the alliance talks would stall."
