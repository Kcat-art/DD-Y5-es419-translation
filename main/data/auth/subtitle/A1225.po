msgstr ""

msgctxt " 	　	　	60	793	733"
msgid "I'm aware, yeah."
msgstr ""

msgctxt " 	　	　	158	979	821"
msgid "If he croaks, the Omi truce\\r\n"
"with the Tojo'll go up in flames."
msgstr ""

msgctxt " 	　	　	87	1088	1001"
msgid "No truce, nothin' to stop an all-out war."
msgstr ""

msgctxt " 	　	　	142	1267	1125"
msgid "So the Tojo Clan has been runnin' around\\r\n"
"the whole country, makin' alliances."
