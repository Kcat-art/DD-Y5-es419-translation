msgctxt " 	　	　	150	3899	3749"
msgid "And what, you tracked me down\\r\n"
"just to tell me all this?"
msgstr ""

msgctxt " 	　	　	61	4030	3969"
msgid "Well, let's not be hasty."
msgstr ""

msgctxt " 	　	分	66	4104	4038"
msgid "I'm just gettin' to my point."
msgstr ""

msgctxt " 	　	　	131	4257	4126"
msgid "You ran into two Tojo goons who\\r\n"
"were supposed to be guardin' Dojima, yeah?"
msgstr ""

msgctxt " 	　	　	125	4402	4277"
msgid "Names're Morinaga and Aizawa, I think?"
msgstr ""

msgctxt " 	　	　	60	4508	4448"
msgid "What about them?"
msgstr ""

msgctxt " 	　	　	117	4642	4525"
msgid "I'm gonna have to ask you to keep\\r\n"
"them from doing anything stupid."
