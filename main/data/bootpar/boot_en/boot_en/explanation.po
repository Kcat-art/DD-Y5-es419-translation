msgid "My lessons with Christina start today. I should go in to the office."
msgstr ""

msgctxt "12902	EXPLANATION"
msgid "Christina is waiting for me. I have to hurry to the studio."
msgstr ""

msgctxt "12962	EXPLANATION"
msgid "I've got to start my lessons. I should go and see Christina."
