msgctxt "44"
msgid "How to Play Nine-ball"
msgstr ""

msgctxt "56"
msgid "Pocket the object balls in order, starting with the lowest number, by hitting them with the cue ball."
msgstr ""

msgctxt "68"
msgid "Your turn continues until you fail to pocket a ball."
msgstr ""

msgctxt "80"
msgid "The first player to sink the 9 ball wins."
msgstr ""

msgctxt "92"
msgid "Fouls"
msgstr ""

msgctxt "104"
msgid "A foul results if the cue ball falls into a pocket or does not strike an object ball."
msgstr ""

msgctxt "116"
msgid "The opposing player may then take a shot by placing the cue ball anywhere on the table."
msgstr ""

msgctxt "128"
msgid "Now, let's have you try it yourself."
msgstr ""

